# PostgreSQL (local ou cloud)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fila_bar?schema=public"

# URL pública da app (para links em emails/WhatsApp em produção)
# NEXT_PUBLIC_APP_URL="https://teu-dominio.com"

# Forçar tentativa de envio WhatsApp em dev (requer integração em lib/whatsapp.ts)
# WHATSAPP_FORCE_SEND="1"

# Área staff (/staff) — login com palavra-passe
# Gera um segredo longo e aleatório (ex.: 32+ caracteres)
STAFF_JWT_SECRET="coloca_aqui_um_segredo_longo_e_aleatorio"
STAFF_PASSWORD="palavra-passe_do_bar_para_o_painel"

# Upload de imagens na cloud (Vercel Blob) — produção na Vercel
# Cria um store em: Vercel Dashboard → Storage → Blob → liga ao projeto
# Depois copia o token ou corre: vercel env pull
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
